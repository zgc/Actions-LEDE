# OpenWrt source (cloned via git)
/openwrt/
/openwrt.bak.*/

# Download cache
/dl/

# Docker build artifacts
/docker/openwrt/

# Ccache
*.ccache

# Build cache & directories
/cache/
/staging_dir/
/build_dir/
/tmp/

# Feeds & packages (cloned via scripts, should live inside openwrt/)
/feeds/
/package/

# Generated firmware, build artifacts & outputs
/release/
/output/

# Log files
*.log

# Runtime files
*.pid

# OS files
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.idea/
.vscode/

# Keep empty directories with .gitkeep
!.gitkeep

# Build config output (generated by make defconfig)
config.buildinfo
